# ── Email (Resend) ────────────────────────────────────────────────
# Quote-form submissions are emailed via Resend (https://resend.com).
# Set ALL of these in Vercel → Settings → Environment Variables (Production),
# and locally in .env.local for testing.

# Your Resend API key (Resend dashboard → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender. Requires a verified domain in Resend.
#   • Before domain verification (testing only): Ovaro Commercial <onboarding@resend.dev>
#     (can only deliver to your own Resend account email)
#   • After verifying the emails.ovarocommercial.com subdomain in Resend:
#     Ovaro Commercial <quotes@emails.ovarocommercial.com>
QUOTE_FROM=Ovaro Commercial <quotes@emails.ovarocommercial.com>

# Where quote requests are delivered
QUOTE_TO=terrell@ovarocommercial.com
